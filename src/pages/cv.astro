---
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CV | Ho Minh Huy</title>
    <meta name="robots" content="noindex,nofollow" />
    <style>
      :root {
        color-scheme: dark;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        width: 100%;
        min-height: 100%;
        margin: 0;
        padding: 0;
        background: #020617;
        color: #e2e8f0;
      }

      .cv-wrap {
        max-width: 980px;
        margin: 0 auto;
        padding: 16px;
      }

      .cv-header {
        position: sticky;
        top: 0;
        z-index: 20;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        margin-bottom: 12px;
        background: rgba(2, 6, 23, 0.85);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(148, 163, 184, 0.25);
        border-radius: 10px;
      }

      .cv-status {
        font: 500 14px/1.3 system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
        color: #cbd5e1;
      }

      .cv-pages {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }

      .cv-page {
        width: 100%;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid rgba(148, 163, 184, 0.25);
        background: #0f172a;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
      }

      .cv-page img {
        width: 100%;
        height: auto;
        display: block;
      }

      .cv-download-group {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }

      .fallback {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 14px;
        border-radius: 8px;
        background: rgba(15, 23, 42, 0.85);
        color: #e2e8f0;
        font: 500 14px/1.3 system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
        text-decoration: none;
        border: 1px solid rgba(148, 163, 184, 0.35);
      }

      .fallback:hover {
        background: rgba(30, 41, 59, 0.9);
      }

      .fallback:focus-visible {
        outline: 2px solid #38bdf8;
        outline-offset: 2px;
      }

      .download-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 10px 14px;
        border-radius: 8px;
        background: linear-gradient(135deg, rgba(56, 189, 248, 0.2), rgba(34, 197, 94, 0.2));
        color: #38bdf8;
        font: 500 14px/1.3 system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
        text-decoration: none;
        border: 1px solid rgba(56, 189, 248, 0.5);
        cursor: pointer;
      }

      .download-btn:hover {
        background: linear-gradient(135deg, rgba(56, 189, 248, 0.3), rgba(34, 197, 94, 0.3));
        border-color: rgba(56, 189, 248, 0.8);
      }

      .download-btn:focus-visible {
        outline: 2px solid #38bdf8;
        outline-offset: 2px;
      }

      .download-icon {
        width: 16px;
        height: 16px;
        display: inline-block;
      }
    </style>
  </head>
  <body>
    <main class="cv-wrap">
      <header class="cv-header">
        <div class="cv-status">CV image preview (Page 1 & 2)</div>
        <div class="cv-download-group">
          <a class="fallback" href="/cv/cv_1.png" data-cv-asset target="_blank" rel="noopener noreferrer">Page 1</a>
          <a class="fallback" href="/cv/cv_2.png" data-cv-asset target="_blank" rel="noopener noreferrer">Page 2</a>
          <a class="download-btn" href="/cv/cv.pdf" data-cv-asset download="cv.pdf" title="Download CV as PDF">
            <svg class="download-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            Download PDF
          </a>
        </div>
      </header>

      <article class="cv-pages">
        <div class="cv-page" aria-label="CV Page 1">
          <img src="/cv/cv_1.png" data-cv-asset alt="CV Page 1 - Ho Minh Huy" loading="eager" decoding="async" />
        </div>
        <div class="cv-page" aria-label="CV Page 2">
          <img src="/cv/cv_2.png" data-cv-asset alt="CV Page 2 - Ho Minh Huy" loading="lazy" decoding="async" />
        </div>
      </article>
    </main>

    <script>
      const cacheVersion = Date.now().toString();
      const withVersion = (url: string): string => {
        try {
          const parsed = new URL(url, window.location.origin);
          parsed.searchParams.set('v', cacheVersion);
          return parsed.pathname + parsed.search;
        } catch {
          return url;
        }
      };

      document.querySelectorAll('[data-cv-asset]').forEach((el) => {
        if (el instanceof HTMLImageElement) {
          el.src = withVersion(el.src);
          return;
        }

        if (el instanceof HTMLAnchorElement) {
          el.href = withVersion(el.href);
        }
      });
    </script>
  </body>
</html>
