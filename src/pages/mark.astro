---
const markImageUrl = '/mark/mark.png';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mark | Ho Minh Huy</title>
    <meta name="robots" content="noindex,nofollow" />
    <style>
      :root {
        color-scheme: dark;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        width: 100%;
        min-height: 100%;
        margin: 0;
        padding: 0;
        background: #020617;
        color: #e2e8f0;
      }

      .mark-wrap {
        max-width: 980px;
        margin: 0 auto;
        padding: 16px;
      }

      .mark-header {
        position: sticky;
        top: 0;
        z-index: 20;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        margin-bottom: 12px;
        background: rgba(2, 6, 23, 0.85);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(148, 163, 184, 0.25);
        border-radius: 10px;
      }

      .mark-status {
        font: 500 14px/1.3 system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
        color: #cbd5e1;
      }

      .mark-page {
        width: 100%;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid rgba(148, 163, 184, 0.25);
        background: #0f172a;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
      }

      .mark-page img {
        width: 100%;
        height: auto;
        display: block;
      }

      .fallback {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 14px;
        border-radius: 8px;
        background: rgba(15, 23, 42, 0.85);
        color: #e2e8f0;
        font: 500 14px/1.3 system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
        text-decoration: none;
        border: 1px solid rgba(148, 163, 184, 0.35);
      }

      .fallback:hover {
        background: rgba(30, 41, 59, 0.9);
      }

      .fallback:focus-visible {
        outline: 2px solid #38bdf8;
        outline-offset: 2px;
      }
    </style>
  </head>
  <body>
    <main class="mark-wrap">
      <header class="mark-header">
        <div class="mark-status">Score image preview</div>
        <a class="fallback" href={markImageUrl} target="_blank" rel="noopener noreferrer">Open Image</a>
      </header>

      <article class="mark-page" aria-label="Score image preview">
        <img src={markImageUrl} alt="Mark score image" loading="eager" decoding="async" />
      </article>
    </main>
  </body>
</html>
